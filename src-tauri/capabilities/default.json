{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Password Keeper",
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:image:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "opener:default",
    "store:default",
    "dialog:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://accounts.google.com/**" },
        { "url": "https://oauth2.googleapis.com/**" },
        { "url": "https://www.googleapis.com/**" }
      ]
    }
  ]
}
