{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile",
  "description": "Capabilities for Android and iOS",
  "platforms": ["android", "iOS"],
  "webviews": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:image:default",
    "core:resources:default",
    "opener:default",
    "store:default",
    "dialog:default",
    "deep-link:default",
    "os:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://**" }]
    }
  ]
}
