# ─── Google OAuth2 ────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha com suas credenciais reais.
# O arquivo .env está no .gitignore e NUNCA deve ser commitado.
#
# Como obter:
#   1. https://console.cloud.google.com → Seu projeto
#   2. APIs e Serviços → Credenciais → Criar credencial → ID do cliente OAuth 2.0
#   3. Tipo: Aplicativo para computador (Desktop app)
#   4. URIs de redirecionamento autorizados:
#        http://localhost:8899            ← Desktop (Linux/Windows/macOS)
#        passwordkeeper://oauth2callback  ← Mobile (Android/iOS)

VITE_GOOGLE_CLIENT_ID=SEU_CLIENT_ID_AQUI.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=GOCSPX-SEU_SECRET_AQUI
