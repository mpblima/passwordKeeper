# ─── Google OAuth2 ────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha com suas credenciais reais.
# O arquivo .env está no .gitignore e NUNCA deve ser commitado.
#
# Como obter:
#   1. https://console.cloud.google.com → Seu projeto
#   2. APIs e Serviços → Credenciais → Criar credencial → ID do cliente OAuth 2.0
#   3. Crie dois clientes OAuth:
#        - Tipo: Aplicativo para computador (Desktop app)
#        - Tipo: Android
#   4. Desktop: URI de redirecionamento autorizado:
#        http://localhost:8899
#   5. Android:
#        Package name: com.passwordkeeper.app
#        SHA-1 debug: E2:BD:02:7F:D3:43:BB:98:D8:5F:B1:3C:8D:97:18:02:F0:47:8C:0B
#        Redirect usado pelo app: com.googleusercontent.apps.<ANDROID_CLIENT_ID_SEM_SUFFIX>:/oauth2redirect

VITE_GOOGLE_CLIENT_ID=SEU_CLIENT_ID_AQUI.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=GOCSPX-SEU_SECRET_AQUI
VITE_GOOGLE_ANDROID_CLIENT_ID=SEU_CLIENT_ID_ANDROID_AQUI.apps.googleusercontent.com
